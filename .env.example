# Copy to .env and fill in your values

# Password to access the mind (single-user)
IMP_PASSWORD=changeme

# Claude API key (required)
ANTHROPIC_API_KEY=sk-ant-...

# JWT signing secret — make this long and random
SESSION_SECRET=change-this-to-a-random-secret-at-least-32-chars

# Server port
PORT=8000

# How often (in REAL seconds) the stream engine generates spontaneous thoughts
SPONTANEOUS_INTERVAL=180

# Mind name shown in the UI
MIND_NAME=IMPLUS
