# Copy to .env and fill in your values

# Your Groq API key (required) — get it at https://console.groq.com
GROQ_API_KEY=gsk_...

# Single-user password to access the mind (write operations)
MIND_PASSWORD=your_password_here

# JWT signing secret — long random string, min 32 chars
SESSION_SECRET=change-this-to-a-random-secret-at-least-32-chars

# SQLite database path (SQLAlchemy URL format, relative to project root)
DATABASE_URL=sqlite:///./data/implus.db

# Time ratio: 1 real second = N mind seconds (default 6 → 10 min real = 1 hr mind)
MIND_TIME_RATIO=6

# How often (in real seconds) the mind generates spontaneous thoughts
STREAM_INTERVAL_SECONDS=180

# Server port
PORT=8000
